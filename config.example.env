# ===========================================
# DuckX Newsfeed - Environment Configuration
# ===========================================
# Hướng dẫn cài đặt:
#   1. Copy file này thành ".env" (bỏ phần .example)
#      Windows:  copy config.example.env .env
#      Linux/Mac: cp config.example.env .env
#   2. Điền đầy đủ các API keys vào bên dưới
#   3. KHÔNG BAO GIỜ commit file .env lên git (đã có trong .gitignore)
# ===========================================


# ===========================================
# X (Twitter) API Credentials
# ===========================================
# Lấy tại: https://developer.x.com/en/portal/dashboard
# Cần tạo Project và App, chọn quyền "Read" là đủ.
#
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here


# ===========================================
# Telegram Bot
# ===========================================
# 1. Tạo bot mới: mở Telegram -> tìm @BotFather -> /newbot -> lấy TOKEN
# 2. Lấy Chat ID:
#    - Chat riêng: Nhắn tin cho bot, sau đó mở URL sau trong trình duyệt:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      Tìm "chat":{"id": xxxxx} -> đó là Chat ID của bạn.
#    - Group/Channel: Thêm bot vào group, gửi 1 tin nhắn, mở URL trên.
#      Chat ID của group sẽ có dấu trừ ở đầu, ví dụ: -1001234567890
#
# Hỗ trợ nhiều Chat ID (gửi đến nhiều người/nhóm cùng lúc):
#    Cách nhau bằng dấu phẩy, ví dụ: TELEGRAM_CHAT_ID="123456789, -1009876543, -1001112223"
#
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Chat ID nhận thông báo lỗi hệ thống (Fetch/AI/Telegram failures). Thường là ID cá nhân của admin.
TELEGRAM_ADMIN_ID=your_admin_chat_id_here


# ===========================================
# AI - Google Gemini Models
# ===========================================
# Lấy API Key mien phi tai: https://aistudio.google.com/apikey
#
# Tip: Tao toi da 3 key tu 3 tai khoan Google khac nhau de dung Free tier luan phien.
#      Paid key co quota cao hon nhieu va khong bi rate limit.
#
# Gemini Free Tier (toc do gioi han, mien phi):
GEMINI_API_KEY_1=your_gemini_key_1_here
GEMINI_API_KEY_2=your_gemini_key_2_here
GEMINI_API_KEY_3=your_gemini_key_3_here

# Gemini Paid Tier (khong gioi han, toc do cao):
GEMINI_API_KEY_PAID=your_gemini_paid_key_here


# ===========================================
# Security (Optional)
# ===========================================
# Nếu để trống: API không yêu cầu auth (local-only mode, an toàn khi bind 127.0.0.1).
# Nếu điền token: tất cả /api/* requests phải gửi kèm header:
#   Authorization: Bearer <token>
#   hoặc: X-Admin-Token: <token>
# Dùng khi expose app ra network nội bộ hoặc public.
#
ADMIN_TOKEN=
